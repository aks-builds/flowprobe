{
  "name": "flowprobe",
  "version": "0.1.0",
  "description": "The Postman for async architectures — event-driven system testing",
  "type": "module",
  "bin": { "flowprobe": "./dist/index.js" },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "@flowprobe/core": "workspace:*",
    "@flowprobe/adapter-kafka": "workspace:*",
